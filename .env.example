APP_ENV=dev
LOG_LEVEL=INFO

# --- Base de datos ---
# SQLite (dev rapido, sin Docker):
DATABASE_URL=sqlite:///./marketing.db
# PostgreSQL (paso 2 en adelante):
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/marketing_mvp

# --- Cola de tareas ---
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
# Origenes permitidos para el navegador. Separados por coma.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# =============================================================================
# PASO 3A — LLMs
# Provider: anthropic | openai  (si ambas claves estan vacias usa stubs mockeados)
# =============================================================================
LLM_PROVIDER=anthropic
# Modelos disponibles: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-7
LLM_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=

# Solo necesario si LLM_PROVIDER=openai
OPENAI_API_KEY=

# =============================================================================
# PASO 3B — Generacion de imagenes
# Provider: mock | openai | canva
# =============================================================================
IMAGE_PROVIDER=mock
# openai: usa DALL-E 3 (requiere OPENAI_API_KEY arriba)
# canva: requiere las tres variables de abajo + implementar OAuth
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_TEMPLATE_ID=

# =============================================================================
# PASO 3C — Publicacion en redes sociales
# Provider: mock | linkedin | uploadpost
# =============================================================================
SOCIAL_PROVIDER=mock

# LinkedIn (SOCIAL_PROVIDER=linkedin)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=   # opcional: se obtiene automaticamente de /v2/me si esta vacio

# Upload-Post (SOCIAL_PROVIDER=uploadpost) — API unificada para multiples plataformas
# Docs: https://upload-post.com/docs/api
UPLOADPOST_API_KEY=

# =============================================================================
# PASO 4 — Seguridad y Human-in-the-loop
# =============================================================================

# API Key para autenticación Bearer. Vacío = auth desactivada (dev local).
# En producción: genera con `python -c "import secrets; print(secrets.token_urlsafe(32))"`
API_KEY=

# Slack Incoming Webhook para notificaciones human-in-the-loop.
# Cuando un run entra en pending_approval, se envía un mensaje a este webhook.
# Crea el webhook en: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# =============================================================================
# Microservicio Go (publicador sidecar)
# =============================================================================
GO_PUBLISHER_URL=http://localhost:8088

